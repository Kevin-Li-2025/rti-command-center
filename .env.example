# llm provider: openai | deepseek | ollama
LLM_PROVIDER=openai

# openai
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# deepseek
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat

# ollama (just run `ollama serve`)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# data sources
NEWSAPI_KEY=
AVIATIONSTACK_KEY=

# pipeline
PIPELINE_INTERVAL_HOURS=4

# server
HOST=0.0.0.0
PORT=8000
